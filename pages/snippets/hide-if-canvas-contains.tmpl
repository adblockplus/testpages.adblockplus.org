{% set case = "drawImage with toDataURL" %}
{% set id = get_id(case) %}
<section id="{{id}}-section" class="testcase-panel">
  {{ heading(case) }}
  <p>Test the snippet when drawImage() is called with an image sourced from toDataURL().</p>
  <div id="{{id}}-area" class="testcase-area">
    <div class="testcase-examplecontent" aria-label="{{id}}-example">Example Content</div>
    <div data-expectedresult="fail" class="tdu-canvas-parent" id="canvas-parent13"><div><span>Failed. Element is not hidden.</span></div></div>
    <div class="testcase-expected-view tdu-canvas-parent" id="canvas-parent14"><div><span>Should not be hidden.</span></div></div>
    <div data-expectedresult="pass" class="tdu-canvas-parent" id="canvas-parent15"><div><span>Should not be hidden.</span></div></div>
    <div class="testcase-waiting-content">Waiting 500ms to trigger snippet...</div>
  </div>
  <h3>Steps</h3>
