  </ul>
  <h3>Filters</h3>
  <ul id="{{id}}-filters" class="testcase-filters">
    <li><pre>{{ site_url|domain }}#$#hide-if-canvas-contains /AAAAoAAAAKCA/ .tdu-canvas-parent</pre></li>
  </ul>
</section>

<script>
  "use strict";

  function createCanvas(method, id, text, x = 0, y = 18) {
    const canvas = document.createElement("canvas");
    canvas.id = id;

    // Get the 2D drawing context from the canvas
    const ctx = canvas.getContext("2d");
    ctx.font = "24px Arial";
    canvas.width = 200;
    canvas.height = 30;
    canvas.style.verticalAlign = "middle"; // Aligns canvas with text
    canvas.style.border = "1px solid #ccc";

    if (method === "fillText") {
      ctx.fillStyle = "white";
      ctx.fillText(text, x, y);
    }
    if (method === "strokeText") {
      ctx.strokeStyle = "white";
      ctx.strokeText(text, x, y);
    }
    if (method === "drawImage") {
      const img = new Image();
      img.onload = () => {
        ctx.drawImage(img, x, y);
      };
      img.src = text;
    }

    return canvas; // Return the created canvas element
  }

  function appendCanvas(parentSelector, method, id, text) {
    const canvasParent = document.querySelector(parentSelector);
    if (canvasParent) {
      const canvas = createCanvas(method, id, text);
      canvasParent.appendChild(canvas);
    }
  }

  // drawImage data URL sources
  const adImageSrc = "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAoAAAAKCAYAAACNMs+9AAAAFElEQVR4nGP4z8DwnxjMMKqQvgoBksPHOas6/LEAAAAASUVORK5CYII="; // eslint-disable-line max-len
  const safeImageSrc = "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAoAAAAKCAYAAACNMs+9AAAAE0lEQVR4nGNgYPj/nzg8qpCuCgHLfMc5VwOF6wAAAABJRU5ErkJggg=="; // eslint-disable-line max-len

  // toDataURL test: create source canvases and extract data URLs
  const adSource = document.createElement("canvas");
  adSource.width = 10;
  adSource.height = 10;
  const adSourceCtx = adSource.getContext("2d");
  adSourceCtx.fillStyle = "red";
  adSourceCtx.fillRect(0, 0, 10, 10);
  const safeSource = document.createElement("canvas");
  safeSource.width = 20;
  safeSource.height = 20;
  const safeSourceCtx = safeSource.getContext("2d");
  safeSourceCtx.fillStyle = "blue";
  safeSourceCtx.fillRect(0, 0, 20, 20);
  const adToDataURLSrc = adSource.toDataURL();
  const safeToDataURLSrc = safeSource.toDataURL();

  setTimeout(() => {
    appendCanvas("#canvas-parent1", "fillText", "canvas1", "sponsored");
    appendCanvas("#canvas-parent2", "fillText", "canvas2", "hello world");
    appendCanvas("#canvas-parent3", "fillText", "canvas3", "hello world");
    appendCanvas("#canvas-parent4", "strokeText", "canvas4", "sponsored");
    appendCanvas("#canvas-parent5", "strokeText", "canvas5", "hello world");
    appendCanvas("#canvas-parent6", "strokeText", "canvas6", "hello world");
    appendCanvas("#canvas-parent7", "drawImage", "canvas7", adImageSrc);
    appendCanvas("#canvas-parent8", "drawImage", "canvas8", safeImageSrc);
    appendCanvas("#canvas-parent9", "drawImage", "canvas9", safeImageSrc);
    appendCanvas("#canvas-parent10", "drawImage", "canvas10", adToDataURLSrc);
    appendCanvas("#canvas-parent11", "drawImage", "canvas11", safeToDataURLSrc);
    appendCanvas("#canvas-parent12", "drawImage", "canvas12", safeToDataURLSrc);
  }, 200);

  setTimeout(() => {
    removeWaitingContent(); // eslint-disable-line no-undef
  }, 500);

</script>
