    <li>Add filter #1.</li>
    <li>Refresh page.</li>
    <li>The red element in the test case above should be hidden and the green one not hidden.</li>
  </ul>
  <h3>Filters</h3>
  <ul id="{{id}}-filters" class="testcase-filters">
    <li><pre>{{ site_url|domain }}#$#hide-if-canvas-contains /AAAAoAAAAKCA/ .tdu-canvas-parent</pre></li>
  </ul>
</section>

<script>
  "use strict";

  function makeCanvas(id) {
    const canvas = document.createElement("canvas");
    canvas.id = id;
    canvas.width = 0;
    canvas.height = 0;
    canvas.style.verticalAlign = "middle";
    const ctx = canvas.getContext("2d");
    ctx.font = "24px Arial";
    return {canvas, ctx};
  }

  function createCanvas(method, id, text, x = 0, y = 18) {
    const {canvas, ctx} = makeCanvas(id);
    if (method === "fillText") {
      ctx.fillStyle = "white";
      ctx.fillText(text, x, y);
    }
    if (method === "strokeText") {
      ctx.strokeStyle = "white";
      ctx.strokeText(text, x, y);
    }
    if (method === "drawImage") {
      const img = new Image();
      img.src = text;
      ctx.drawImage(img, x, y);
    }
    return canvas;
  }

  function appendCanvas(parentSelector, method, id, text) {
    const canvasParent = document.querySelector(parentSelector);
    if (canvasParent) {
      const canvas = createCanvas(method, id, text);
      canvasParent.appendChild(canvas);
    }
  }

  function appendCanvasCharByChar(parentSelector, id, text) {
    const canvasParent = document.querySelector(parentSelector);
    if (canvasParent) {
      const {canvas, ctx} = makeCanvas(id);
      ctx.strokeStyle = "white";
      let x = 0;
      for (const char of text) {
        ctx.strokeText(char, x, 18);
        x += 14;
      }
      canvasParent.appendChild(canvas);
    }
  }

  // toDataURL test: create source canvases and extract data URLs
  const adSource = document.createElement("canvas");
  adSource.width = 10;
  adSource.height = 10;
  const adSourceCtx = adSource.getContext("2d");
  adSourceCtx.fillStyle = "red";
  adSourceCtx.fillRect(0, 0, 10, 10);
  const safeSource = document.createElement("canvas");
  safeSource.width = 20;
  safeSource.height = 20;
  const safeSourceCtx = safeSource.getContext("2d");
  safeSourceCtx.fillStyle = "blue";
  safeSourceCtx.fillRect(0, 0, 20, 20);
  const adToDataURLSrc = adSource.toDataURL();
  const safeToDataURLSrc = safeSource.toDataURL();

  setTimeout(() => {
    appendCanvas("#canvas-parent1", "fillText", "canvas1", "sponsored");
    appendCanvas("#canvas-parent2", "fillText", "canvas2", "hello world");
    appendCanvas("#canvas-parent3", "fillText", "canvas3", "hello world");
    appendCanvas("#canvas-parent4", "strokeText", "canvas4", "sponsored");
    appendCanvas("#canvas-parent5", "strokeText", "canvas5", "hello world");
    appendCanvas("#canvas-parent6", "strokeText", "canvas6", "hello world");
    appendCanvasCharByChar("#canvas-parent7", "canvas7", "sponsored");
    appendCanvasCharByChar("#canvas-parent8", "canvas8", "hello world");
    appendCanvasCharByChar("#canvas-parent9", "canvas9", "hello world");
    appendCanvas("#canvas-parent10", "drawImage", "canvas10", "https://example.com/ads/banner.png");
    appendCanvas("#canvas-parent11", "drawImage", "canvas11", "https://example.com/content/image.png");
    appendCanvas("#canvas-parent12", "drawImage", "canvas12", "https://example.com/content/image.png");
    appendCanvas("#canvas-parent13", "drawImage", "canvas13", adToDataURLSrc);
    appendCanvas("#canvas-parent14", "drawImage", "canvas14", safeToDataURLSrc);
    appendCanvas("#canvas-parent15", "drawImage", "canvas15", safeToDataURLSrc);
  }, 200);

  setTimeout(() => {
    removeWaitingContent(); // eslint-disable-line no-undef
  }, 500);

</script>
