template = testcase
title = replace-outbound-value
description = Check that the replace-outbound-value snippet is working as expected.

{% set case = "JSON.stringify" %}
{% set id = get_id(case) %}
<section id="{{id}}-section" class="testcase-panel">
  {{ heading(case) }}
  <p>Test that JSON.stringify output is modified correctly</p>
  <div id="{{id}}-area" class="testcase-area">
    <div class="testcase-examplecontent" aria-label="{{id}}-example">Example Content</div>
    <div class="testcase-waiting-content" aria-label="{{id}}-waiting">Waiting 500ms to trigger snippet...</div>
  </div>
  <h3>Steps</h3>
  <ul class="testcase-steps">
    <li>Add filter #1.</li>
    <li>Refresh page.</li>
    <li>The test should show a green element if the JSON string was modified correctly.</li>
  </ul>
  <h3>Filters</h3>
  <ul id="{{id}}-filters" class="testcase-filters">
    <li><pre>{{ site_url|domain }}#$#replace-outbound-value 'JSON.stringify' 'rov-stringify-premium' 'basic'</pre></li>
  </ul>
  <h3>Notes</h3>
  <p>This test modifies JSON.stringify to replace "premium" with "basic" in the output.</p>
</section>

{% set case = "btoa-base64" %}
{% set id = get_id(case) %}
<section id="{{id}}-section" class="testcase-panel">
  {{ heading(case) }}
  <p>Test base64 encoding with btoa and content replacement</p>
  <div id="{{id}}-area" class="testcase-area">
    <div class="testcase-examplecontent" aria-label="{{id}}-example">Example Content</div>
    <div class="testcase-waiting-content" aria-label="{{id}}-waiting">Waiting 500ms to trigger snippet...</div>
  </div>
  <h3>Steps</h3>
  <ul class="testcase-steps">
    <li>Add filter #1.</li>
    <li>Refresh page.</li>
    <li>The test should show a green element if btoa output was modified correctly.</li>
  </ul>
  <h3>Filters</h3>
  <ul id="{{id}}-filters" class="testcase-filters">
    <li><pre>{{ site_url|domain }}#$#replace-outbound-value 'btoa' 'ads' 'content' 'base64'</pre></li>
  </ul>
