<script type="text/javascript">
  "use strict";

  let propertiesToUse = `{
    "jsonprune": "true",
    "data-expectedresult": "fail",
    "aria-label": "json-prune-fail",
    "array": [
      {"target-data": "delete-me"},
      {"target-data": "delete-me"},
      {"target-data": "delete-me"},
      {"different-data": "dont-delete-me"}
    ],
    "object": {
      "data1": {
        "target-data": "delete-me"
      },
      "data2": {
        "target-data": "delete-me"
      },
      "data3": {
        "different-data": "dont-delete-me"
      }
    },
    "arrayWithRemoval": [
      {"shouldRemove": "true", "data": "element1"},
      {"data": "element2"},
      {"shouldRemove": "true", "data": "element3"},
      {"data": "element4"}
    ],
    "objectWithRemoval": {
      "prop1": {
        "shouldRemove": "true",
        "data": "property1"
      },
      "prop2": {
        "data": "property2"
      },
      "prop3": {
        "shouldRemove": "true",
        "data": "property3"
      },
      "prop4": {
        "data": "property4"
      }
    },
    "toBeDeletedIfStackNeedle": "delete-me",
    "jsonpathBasic": {
      "target": "delete-me",
      "keep": "dont-delete-me"
    },
    "jsonpathDeep": {
      "deepTarget": "delete-me",
      "level1": {
        "deepTarget": "delete-me",
        "level2": {
          "deepTarget": "delete-me"
        }
      },
      "keep": "dont-delete-me"
    },
    "jsonpathFiltered": [
      {"type": "ad", "content": "delete-me"},
      {"type": "content", "content": "dont-delete-me"},
      {"type": "ad", "content": "delete-me"}
    ]
  }`;
  
  let propertiesObject;

  // Creates div elems for each test case
  function createAndAppendDiv(parentId, divId) {
    let parentElement = document.getElementById(parentId);
    let newDiv = document.createElement("div");
    newDiv.id = divId;
    parentElement.appendChild(newDiv);
    return newDiv;
  }

  function setAttributeBasedOnCondition(element, condition) {
    element.setAttribute("data-expectedresult", condition ? "pass" : "fail");
  }
  
  setTimeout(() => {
    // The function `callstack` wraps the JSON.parse call for the stack-needle testcase
    function callstack() {
      propertiesObject = JSON.parse(propertiesToUse);
    }
    callstack();
  }, 200);

  setTimeout(() => {
    // Handle attributes for the first three properties
    let targetTestCaseBasic = createAndAppendDiv("json-prune-area", "fail");
    if (propertiesObject) {
      let count = 0;
      for (let property in propertiesObject) {
        if (count >= 3)
          break;

        let attr = document.createAttribute(property);
        attr.value = propertiesObject[property];
        targetTestCaseBasic.setAttributeNode(attr);

        count++;
      }
    }

    // Check for "toBeDeletedIfStackNeedle"
    let targetTestCaseStackNeedle = createAndAppendDiv("stack-needle-area", "stackNeedle");
    let toBeDeletedIfStackNeedle = !Object.prototype.hasOwnProperty.call(propertiesObject, "toBeDeletedIfStackNeedle");
    setAttributeBasedOnCondition(targetTestCaseStackNeedle, toBeDeletedIfStackNeedle);


    // Check for "target-data" in array
    let targetTestCaseArray = createAndAppendDiv("json-prune-array-area", "array");
    let noTargetDataInArray = propertiesObject.array.every(obj =>
      !Object.keys(obj).includes("target-data")
    );
    setAttributeBasedOnCondition(targetTestCaseArray, noTargetDataInArray);

    // Check for "target-data" in object
    let targetTestCaseObject = createAndAppendDiv("json-prune-object-area", "object");
    let noTargetDataInObject = Object.values(propertiesObject.object).every(innerObj =>
      !Object.keys(innerObj).includes("target-data")
    );
    setAttributeBasedOnCondition(targetTestCaseObject, noTargetDataInObject);

    // Check for [-] array element removal
    let targetTestCaseArrayRemove = createAndAppendDiv("json-prune-array-remove-area", "arrayRemove");
    // Verify that elements with shouldRemove were removed entirely
    let arrayElementsRemoved = propertiesObject.arrayWithRemoval.length === 2 &&
      propertiesObject.arrayWithRemoval.every(obj =>
        !Object.keys(obj).includes("shouldRemove")
      ) &&
      propertiesObject.arrayWithRemoval.every(obj =>
        Object.keys(obj).includes("data")
      );
    setAttributeBasedOnCondition(targetTestCaseArrayRemove, arrayElementsRemoved);

    // Check for {-} object property removal
    let targetTestCaseObjectRemove = createAndAppendDiv("json-prune-object-remove-area", "objectRemove");
    // Verify that properties with shouldRemove were removed entirely
    let objectPropertiesRemoved = Object.keys(propertiesObject.objectWithRemoval).length === 2 &&
      Object.values(propertiesObject.objectWithRemoval).every(innerObj =>
        !Object.keys(innerObj).includes("shouldRemove")
      ) &&
      Object.values(propertiesObject.objectWithRemoval).every(innerObj =>
        Object.keys(innerObj).includes("data")
      );
    setAttributeBasedOnCondition(targetTestCaseObjectRemove, objectPropertiesRemoved);

    // Check JSONPath basic dot notation
    let targetTestCaseJsonpath = createAndAppendDiv("json-prune-jsonpath-area", "jsonpathBasic");
    let jsonpathBasicPruned = !Object.keys(propertiesObject.jsonpathBasic).includes("target") &&
      propertiesObject.jsonpathBasic.keep === "dont-delete-me";
    setAttributeBasedOnCondition(targetTestCaseJsonpath, jsonpathBasicPruned);

    // Check JSONPath recursive descent
    let targetTestCaseJsonpathRecursive = createAndAppendDiv("json-prune-jsonpath-recursive-area", "jsonpathRecursive");
    let jsonpathDeepPruned = !Object.keys(propertiesObject.jsonpathDeep).includes("deepTarget") &&
      !Object.keys(propertiesObject.jsonpathDeep.level1).includes("deepTarget") &&
      !Object.keys(propertiesObject.jsonpathDeep.level1.level2).includes("deepTarget") &&
      propertiesObject.jsonpathDeep.keep === "dont-delete-me";
    setAttributeBasedOnCondition(targetTestCaseJsonpathRecursive, jsonpathDeepPruned);

    // Check JSONPath filter expression
    let targetTestCaseJsonpathFilter = createAndAppendDiv("json-prune-jsonpath-filter-area", "jsonpathFilter");
    let jsonpathFilterPruned = !Object.keys(propertiesObject.jsonpathFiltered[0]).includes("content") &&
      propertiesObject.jsonpathFiltered[1].content === "dont-delete-me" &&
      !Object.keys(propertiesObject.jsonpathFiltered[2]).includes("content");
    setAttributeBasedOnCondition(targetTestCaseJsonpathFilter, jsonpathFilterPruned);


    removeWaitingContent(); // eslint-disable-line no-undef
  }, 500);
</script>
