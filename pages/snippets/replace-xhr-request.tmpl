{% set case = "JSONPath append" %}
{% set id = get_id(case) %}
<section id="{{id}}-section" class="testcase-panel">
  {{ heading(case) }}

  <p>Test that JSONPath append mode pushes a value into an existing array in the request body.</p>
  <div id="test-{{id}}" class="testcase-area">
    <div class="testcase-examplecontent" aria-label="{{id}}-example">Example Content</div>
    <div class="testcase-waiting-content" aria-label="{{id}}-waiting">Waiting 500ms to trigger snippet...</div>
    <div class="testcase-expected-view">XHR request body was replaced</div>
  </div>
  <h3>Steps</h3>
  <ul class="testcase-steps">
    <li>Add filter #1.</li>
    <li>Refresh page.</li>
    <li>The script should display a green element and not a red element to the test case above.</li>
  </ul>
  <h3>Filters</h3>
  <ul id="{{id}}-filters" class="testcase-filters">
    <li><pre>{{ site_url|domain }}#$#replace-xhr-request 'jsonpath($.tags)' '"appended-tag"' '' append</pre></li>
  </ul>
</section>

<script>
  "use strict";

  // Register the echo service worker early so it is active when the tests run.
  // The SW intercepts POST /xhr-request-echo and returns the body as-is,
  // allowing the test to verify what the snippet sent.
  const swReady = "serviceWorker" in navigator ?
    navigator.serviceWorker.register("/xhr-echo-sw.js")
      .then(() => navigator.serviceWorker.ready) : Promise.resolve();

  // A promisified XHR POST request
  function makeXhrPost(body) {
    return new Promise((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      xhr.open("POST", "/xhr-request-echo");
      xhr.setRequestHeader("Content-Type", "text/plain");
      xhr.onload = function() {
        if (xhr.status >= 200 && xhr.status < 300)
          resolve(xhr.response);
        else
          reject({status: xhr.status, statusText: xhr.statusText});
      };
      xhr.onerror = function() {
        reject({status: xhr.status, statusText: xhr.statusText});
      };
      xhr.send(body);
    });
  }

  function handleResult(testId, passed) {
    const testElement = document.getElementById(testId);
    const element = document.createElement("div");
    element.setAttribute("data-expectedresult", passed ? "pass" : "fail");
    element.setAttribute("aria-label", passed ? `${testId}-pass` : `${testId}-fail`);
    element.innerHTML = passed ?
      "XHR request body was replaced" :
      "Failed. XHR request body was not replaced";
    testElement.appendChild(element);
  }

  setTimeout(() => {
    const requests = [
      {
        id: "test-basic",
        body: '{"trackingId":"abc123","data":"keep"}',
        check: response => !response.includes("trackingId") &&
          response.includes("blocked")
      },
      {
        id: "test-regex",
        body: '{"adSlot":"ad12345","content":"good"}',
        check: response => !response.includes("ad12345") &&
          response.includes("removed")
      },
      {
        id: "test-needle",
        body: '{"userId":"user1","analytics":"tracking-data"}',
        check: response => !response.includes("userId") &&
          response.includes("blocked")
      },
      {
        id: "test-jsonpath",
        body: '{"ads":{"enabled":true,"count":5}}',
        check: response => !response.includes("true") &&
          response.includes("jsonpath-replaced")
      },
      {
        id: "test-jsonpath-append",
        body: '{"tags":["sports","news"]}',
        check: response => response.includes("sports") &&
          response.includes("news") &&
          response.includes("appended-tag")
      }
    ];

    swReady.then(() => Promise.all(
      requests.map(({id, body, check}) =>
        makeXhrPost(body)
        .then(response => handleResult(id, check(response)))
        .catch(() => handleResult(id, false))
      )
    )).then(() => {
      removeWaitingContent(); // eslint-disable-line no-undef
    });
  }, 500);
</script>
