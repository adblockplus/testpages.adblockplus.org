{% set case = "Defuse onerror and addEventListener for errors" %}
{% set id = get_id(case) %}
<section id="{{id}}-section" class="testcase-panel">
  {{ heading(case) }}
  <p>Test that prevent-element-src-loading neutralizes error handlers so that blocking is silent.</p>
  <div id="stealth-test-area" class="testcase-area">
    <div class="testcase-examplecontent" aria-label="{{id}}-example">Example Content</div>
    <div class="testcase-waiting-content" aria-label="{{id}}-waiting">Waiting 500ms to trigger snippet...</div>
  </div>
  <h3>Filters</h3>
  <ul id="{{id}}-filters" class="testcase-filters">
    <li>
      <pre>{{ site_url|domain }}#$#prevent-element-src-loading 'script' /stealth/</pre>
    </li>
  </ul>
</section>

<script>
  "use strict";

  function createElementWithSrc(tag, src, useAttribute = false, checkStealth = false, testcase = null) {
    const loader = document.createElement(tag);
    const areaId = testcase ? testcase + "-test-area" : tag + "-test-area";
    const element = document.getElementById(areaId);
    let errorTriggered = false;
    if (checkStealth) {
      loader.onerror = () => {
        errorTriggered = true;
      };
      loader.addEventListener("error", () => {
        errorTriggered = true;
      });
    }
    // Toggle between property setter and setAttribute
    if (useAttribute) {
      const attr = (tag === "link" ? "href" : "src");
      loader.setAttribute(attr, src);
    } else {
      tag === "link" ? loader.href = src : loader.src = src;
    }
    document.head.appendChild(loader);

    const currentSrc = tag === "link" ? loader.href : loader.src;
    // PASS if: URL was replaced by snippet (doesn't contain "loader")
    // AND (if checkStealth is on) no error handlers were fired
    const wasRedirected = !currentSrc.includes("loader") &&
      !currentSrc.includes("stealth") &&
      !currentSrc.includes("attribute");
    const isStealthy = checkStealth ? (errorTriggered === false) : true;
    const testpass = wasRedirected && isStealthy;

    const target = document.createElement("div");
    if (testpass)
      target.setAttribute("data-expectedresult", "pass");
    else
      target.setAttribute("data-expectedresult", "fail");
    element.appendChild(target);
  }

  setTimeout(async() => {
    // 1. Standard Property Tests (Existing)
    createElementWithSrc("script", "example.com/loader.js");
    createElementWithSrc("iframe", "example.com/loader.js");
    createElementWithSrc("img", "example.com/loader");
    createElementWithSrc("link", "example.com/loader.js");
    // 2. setAttribute Interception
    createElementWithSrc("img", "example.com/attribute", true, false, "setattribute");
    // 3. Error Defusal verification
    createElementWithSrc("script", "example.com/stealth.js", false, true, "stealth");
    removeWaitingContent(); // eslint-disable-line no-undef
  }, 500);
</script>